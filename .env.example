# Drizzle — local dev: docker compose up -d postgres
# Production: Supabase supavisor pooler URL (transaction mode, port 6543)
DATABASE_URL=postgres://duosync:duosync@localhost:5433/duosync

ORIGIN="http://localhost:5173"

# Supabase project — required for auth + realtime + cloud DB
# Dashboard → Project Settings → API Keys
PUBLIC_SUPABASE_URL=""
# New-style publishable key (sb_publishable_...). Safe to expose to the browser.
PUBLIC_SUPABASE_PUBLISHABLE_KEY=""

# New-style secret key (sb_secret_...). Server-only, bypasses RLS via the
# service_role JWT template. NEVER expose to the browser.
SUPABASE_SECRET_KEY=""

# Personal access token for the Supabase MCP server (this dev environment only)
# https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=""

# Google OAuth — paste these into Supabase Dashboard → Auth → Providers → Google.
# Not consumed by app code (Supabase Auth handles the OAuth dance).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
