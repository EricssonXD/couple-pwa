{
	"type": "AdaptiveCard",
	"$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
	"version": "1.5",
	"body": [
		{
			"type": "TextBlock",
			"text": "${title}",
			"size": "Small",
			"weight": "Default",
			"color": "Accent",
			"horizontalAlignment": "Center"
		},
		{
			"type": "TextBlock",
			"text": "${days}",
			"size": "ExtraLarge",
			"weight": "Bolder",
			"horizontalAlignment": "Center",
			"spacing": "None"
		},
		{
			"type": "TextBlock",
			"text": "${subtitle}",
			"size": "Small",
			"isSubtle": true,
			"horizontalAlignment": "Center",
			"spacing": "None",
			"wrap": true
		}
	],
	"actions": [
		{
			"type": "Action.OpenUrl",
			"title": "Open DuoSync",
			"url": "${openUrl}"
		}
	]
}
